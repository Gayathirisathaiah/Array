class Solution {
    public int maxProfit(int[] prices) {
        int n=prices.length;
        int buy=prices[0];
        int p=0;
        for(int i=0;i<n;i++)
        {
            if(buy>prices[i]) buy=prices[i];
            else {
                p=Math.max(p,prices[i]-buy);
            }
                    }
        return p;
    }
}
